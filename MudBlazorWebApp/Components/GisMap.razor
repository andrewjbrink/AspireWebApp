@using MudBlazorWebApp.Extensions
@inject IJSRuntime js
@* @rendermode InteractiveServer *@
@inject JavaHelper javaHelper

 
<div id="status"></div>
<div id="viewDiv" >
    @* <calcite-loader active="false"
                    type="indeterminate"
                    scale="m"
                    value="0"
                    id="calcite-loader"
                    role="progressbar">
    </calcite-loader> *@

</div>

@code {


    // private IJSObjectReference? module;

    override protected void OnInitialized()
    {
        base.OnInitialized();
    }   

    override protected async Task OnAfterRenderAsync(bool firstRender)
    {
       

        if (firstRender)
        {
           await javaHelper.LoadMainModel();
        }
    }
    
}
<style>
    #viewDiv {
        height: 90vh;
        width: 100%;
        
    }
  
    #info {
        box-sizing: border-box;
        padding: 15px;
        height: 225px;
        width: 350px;
        background: #232b2b;
        color: white;
        font-size: 16px;
        line-height: 30px;
        overflow: auto;
        overflow-wrap: break-word;
    }

        #info span {
            font-weight: 600;
            color: #f7be81;
        }

    .address-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
        color: #f7be81;
    }

        .address-table thead {
            background: #f5f5f5;
            border-bottom: 2px solid #ccc;
        }

        .address-table th {
            padding: 8px 10px;
            text-align: left;
            font-weight: 600;
            border-right: 1px solid #ddd;
        }

            .address-table th:last-child {
                border-right: none;
            }

        .address-table td {
            padding: 8px 10px;
            border-bottom: 1px solid #e0e0e0; /* row separator */
            border-right: 1px solid #f0f0f0;
        }

            #address-table td:last-child {
                border-right: none;
            }

        /* Hover effect */
        .address-table tbody tr:hover {
            background-color: #f0f8ff;
            cursor: pointer;
        }

        /* Optional: selected row highlight */
        .address-table tbody tr.selected {
            background-color: #d7eaff;
        }

    /* tr:nth-child(even) {
        background-color: #dddddd;
    } */

    .zoom-btn {
        background-color: #808080;
        color: white;
        border: none;
        padding: 6px 12px;
        border-radius: 4px;
        font-size: 12px;
        cursor: pointer;
        transition: background-color 0.2s ease;
    }

        .zoom-btn:hover {
            background-color: #005a8e;
        }

        .zoom-btn:active {
            background-color: #003f63;
        }

</style>

@* https://html-color.codes/ *@